# Gemini API key (REQUIRED)
# Get your key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Atlas or local MongoDB URI (OPTIONAL)
# If left blank or connection fails, the system falls back to a high-fidelity local JSON database.
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=qwen_islandflow

# LLM Provider selection: gemini or qwen (REQUIRED)
LLM_PROVIDER=qwen

# Qwen Config (Required if LLM_PROVIDER=qwen)
# Qwen uses standard OpenAI-compatible endpoints or DashScope
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_MODEL=qwen-plus

# Alibaba Cloud OSS Config (OPTIONAL - system will fall back to local sandbox simulator if keys are empty)
ALI_OSS_ACCESS_KEY_ID=your_ali_oss_access_key_id_here
ALI_OSS_ACCESS_KEY_SECRET=your_ali_oss_access_key_secret_here
ALI_OSS_ENDPOINT=oss-ap-southeast-1.aliyuncs.com
ALI_OSS_BUCKET=your_ali_oss_bucket_name_here

# Port to run the FastAPI backend (OPTIONAL)
PORT=8000


